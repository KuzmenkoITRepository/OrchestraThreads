POSTGRES_DB=orchestra_threads
POSTGRES_USER=orchestra
POSTGRES_PASSWORD=orchestra

ORCHESTRA_THREADS_DATABASE_URL=postgresql://orchestra:orchestra@postgres:5432/orchestra_threads
ORCHESTRA_THREADS_DB_SCHEMA=public
ORCHESTRA_THREADS_DB_MIN_POOL_SIZE=5
ORCHESTRA_THREADS_DB_MAX_POOL_SIZE=20
ORCHESTRA_THREADS_DB_COMMAND_TIMEOUT_SECONDS=10

ORCHESTRA_THREADS_HOST=0.0.0.0
ORCHESTRA_THREADS_PORT=8788
ORCHESTRA_THREADS_AGENT_LEASE_SECONDS=30
ORCHESTRA_THREADS_DELIVERY_POLL_INTERVAL_SECONDS=1
ORCHESTRA_THREADS_INACTIVITY_TIMEOUT_SECONDS=60
ORCHESTRA_THREADS_RETRY_BASE_SECONDS=2
ORCHESTRA_THREADS_RETRY_MAX_SECONDS=30

OMNIROUTE_STATE_PATH=/app/.omniroute/proxy-state.json
OMNIROUTE_INITIAL_PASSWORD=CHANGEME
OMNIROUTE_API_KEY=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_PORT=3000
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=changeme-generate-a-secure-secret
LANGFUSE_SALT=changeme-generate-a-secure-salt
LANGFUSE_TELEMETRY_ENABLED=false

OPENAI_API_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=MiniMax-M2.7

VAULT_ADDR=
VAULT_ROLE_ID_DEV=
VAULT_SECRET_ID_DEV=
VAULT_ROLE_ID_STG=
VAULT_SECRET_ID_STG=
VAULT_ROLE_ID_PROD=
VAULT_SECRET_ID_PROD=
COMPOSE_PROJECT_PREFIX=orchestrathreads
OT_DEPLOY_REF=
OT_KEEP_RUNTIME_ENV_FILE=0
OT_PORT_THREADS=8788
OT_PORT_EVENTS=8789
OT_PORT_AGENTS=8790
OT_PORT_TASK_REGISTRY=8791
OT_PORT_SCHEDULER=8792
OT_PORT_LANGFUSE=3000
OT_PORT_OMNIROUTE=20229
OT_PORT_WET=8100
OT_PORT_WET_ADMIN=8101
